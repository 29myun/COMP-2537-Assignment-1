<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <%- include('./templates/header'); %>
    <div class="d-<%= displayNotLoggedIn %> flex-column align-items-center justify-content-center vh-100 text-center">
        <h1 class="mb-3">Welcome</h1>
        <p class="text-muted mb-4">Please log in or create an account to continue.</p>
        <div class="d-flex gap-3">
            <a href="/login" class="btn btn-outline-primary px-4">Login</a>
            <a href="/signup" class="btn btn-primary px-4">Sign Up</a>
        </div>
    </div>
    <div class="d-<%= displayLoggedIn %> flex-column align-items-center justify-content-center vh-100 text-center">
        <h1 class="mb-5">Welcome Back <%= username %></h1>
        <div class="d-flex gap-3">
            <a href="/members" class="btn btn-primary px-4">Go to members</a>
        </div>
    </div>
    <%- include('./templates/footer'); %>
</body>
</html>
