<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Features</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <%- include('./templates/header'); %>

    <div class="container my-5">

        <!-- Hero -->
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold">Features</h1>
            <p class="lead text-muted">Everything you need, all in one place.</p>
        </div>

        <!-- Feature Cards -->
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card h-100 shadow-sm text-center p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3">&#9889;</div>
                        <h5 class="card-title fw-semibold">Fast Performance</h5>
                        <p class="card-text text-muted">Blazing fast load times with optimized infrastructure built for scale.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm text-center p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3">&#128274;</div>
                        <h5 class="card-title fw-semibold">Secure by Default</h5>
                        <p class="card-text text-muted">Your data is encrypted and protected with industry-standard security practices.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm text-center p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3">&#128200;</div>
                        <h5 class="card-title fw-semibold">Analytics</h5>
                        <p class="card-text text-muted">Gain insights with real-time analytics and detailed reporting dashboards.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm text-center p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3">&#127757;</div>
                        <h5 class="card-title fw-semibold">Global Access</h5>
                        <p class="card-text text-muted">Access your account from anywhere in the world on any device.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm text-center p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3">&#129309;</div>
                        <h5 class="card-title fw-semibold">24/7 Support</h5>
                        <p class="card-text text-muted">Our support team is always available to help you whenever you need it.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm text-center p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3">&#128296;</div>
                        <h5 class="card-title fw-semibold">Customizable</h5>
                        <p class="card-text text-muted">Tailor the platform to your needs with flexible settings and integrations.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="text-center py-4 bg-light rounded shadow-sm">
            <h3 class="fw-semibold">Ready to get started?</h3>
            <p class="text-muted">Sign up today and experience everything we have to offer.</p>
            <a href="/signup" class="btn btn-primary px-4">Get Started</a>
        </div>

    </div>

    <%- include('./templates/footer'); %>
</body>
</html>
